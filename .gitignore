# OS / editor
.DS_Store
*.swp

# Node
node_modules/
npm-debug.log*
*.tgz

# Forge runtime artifacts (generated, never committed)
.forge/
*.log
.remember/logs/

# Emitted tool configs — generated by `forge init`/`forge sync` from source/*.
