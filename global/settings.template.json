{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 30,
  "statusLine": {
    "type": "command",
    "command": "bash",
    "args": ["~/.forge/statusline.sh"]
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(ls:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build)",
      "Bash(yarn lint)",
      "Bash(yarn test:*)",
      "Bash(node --version)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(npm ci)",
      "Bash(npm install:*)",
      "Bash(pnpm install:*)",
      "Bash(yarn install:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Read(./secrets/**)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cortex.sh", "prompt"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cortex.sh", "preflight"]
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/recall-load.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cortex.sh", "session-start"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/protect-paths.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cost-budget.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/doom-loop.sh"]
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cortex.sh", "pre-edit"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/format-on-edit.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cortex.sh", "capture"]
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|WebFetch|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/secret-redact.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cortex.sh", "capture"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/completion-gate.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/lean-guard.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/session-learner.sh"]
          },
          {
            "type": "command",
            "command": "bash",
            "args": ["~/.forge/guards/cortex.sh", "stop"]
          }
        ]
      }
    ]
  }
}
