# (.mcp.json is intentionally tracked and NOT ignored.)
/AGENTS.md
/CLAUDE.md
/.codex/
/.cursor/
/.gemini/
/.continue/
/.roo/
/.zed/
/.vscode/
/.aider.conf.yml

# Python bytecode (research prototypes)
__pycache__/
*.py[cod]

# Local scratch
/.playwright-mcp/
/voltra-desktop.jpeg

# Local backups the installer creates
.backup-*/
