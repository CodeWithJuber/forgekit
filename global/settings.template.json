{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 30,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.forge/statusline.sh"
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npm ci)",
      "Bash(pnpm lint)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build)",
      "Bash(yarn lint)",
      "Bash(yarn test:*)",
      "Bash(node --version)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Read(./secrets/**)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cortex.sh prompt"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cortex.sh preflight"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.forge/guards/recall-load.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cortex.sh session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.forge/guards/protect-paths.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cost-budget.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/doom-loop.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cortex.sh pre-edit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.forge/guards/format-on-edit.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cortex.sh capture"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.forge/guards/secret-redact.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cortex.sh capture"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.forge/guards/lean-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/session-learner.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.forge/guards/cortex.sh stop"
          }
        ]
      }
    ]
  }
}
